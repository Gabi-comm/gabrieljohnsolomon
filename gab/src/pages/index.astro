---
import Layout from '../layouts/Layout.astro';
---

<Layout>
<div class="home-content">
        <h1>Hello, I'm Gabriel! </h1>
        <p>Welcome to my portfolio.</p>
    </div>
</Layout>
<style>
    /* These styles will only apply to this specific index page */
    .home-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-top: 15vh; 
        text-align: center;
    }

    h1 {
        font-size: 3rem;
        margin-bottom: 10px;
    }

    p {
        font-size: 1.2rem;
        opacity: 0.8;
    }
</style>